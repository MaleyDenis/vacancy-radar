#!/bin/bash
BRANCH=$(git branch --show-current)
VALID_TYPES="feat fix refactor docs style test chore"

if [[ "$BRANCH" =~ ^(main|master|develop)$ ]]; then
  echo "❌ Blocked: cannot commit directly to '$BRANCH'" >&2
  exit 1
fi

PREFIX=$(echo "$BRANCH" | cut -d'/' -f1)

if ! echo "$VALID_TYPES" | grep -qw "$PREFIX"; then
  echo "❌ Invalid branch type: '$PREFIX'" >&2
  echo "" >&2
  echo "   Valid types:" >&2
  echo "     feat     — new feature" >&2
  echo "     fix      — bug fix" >&2
  echo "     refactor — code restructuring" >&2
  echo "     docs     — documentation" >&2
  echo "     style    — formatting" >&2
  echo "     test     — tests" >&2
  echo "     chore    — build/tools/config" >&2
  exit 1
fi

if [[ "$PREFIX" != "chore" ]]; then
  if ! [[ "$BRANCH" =~ ^(feat|fix|refactor|docs|style|test)/VC-[0-9]{2,3}-[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
    echo "❌ Invalid branch name: '$BRANCH'" >&2
    echo "" >&2
    echo "   Expected format: <type>/VC-<00-999>-short-description" >&2
    echo "" >&2
    echo "   Examples:" >&2
    echo "     feat/VC-123-add-scraper" >&2
    echo "     fix/VC-12-fix-parser" >&2
    echo "     chore/setup-project    ← no ticket required for chore" >&2
    exit 1
  fi
fi

exit 0
